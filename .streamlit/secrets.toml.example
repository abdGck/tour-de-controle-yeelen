# Fichier exemple — renomme en secrets.toml pour usage local
# Sur Streamlit Cloud, ces valeurs se mettent dans App Settings > Secrets

# URL de ton serveur Flask (Render)
FLASK_URL = "https://ton-app.onrender.com"

# Clé de sécurité interne — DOIT être identique à la variable INTERNAL_API_KEY
# définie sur Render. Laisse vide (ou supprime la ligne) si tu n'as pas activé la sécurité.
INTERNAL_API_KEY = ""
